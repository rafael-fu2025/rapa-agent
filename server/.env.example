# ----------------------------------------------------------------------------
# Server environment configuration template.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ----------------------------------------------------------------------------

# Database connection string.
#
# Default for personal-machine use: SQLite. The whole DB is a single
# file in `server/prisma/dev.db` (relative to the schema.prisma file)
# — no daemon, no port, trivial to back up. Perfect for a single-user
# web app that lives on one computer.
#
# For a hosted / multi-user deployment, switch the `provider` in
# `server/prisma/schema.prisma` to `"mysql"` or `"postgresql"` and
# point DATABASE_URL at the production database, e.g.:
#   DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/recreate_ui"
DATABASE_URL="file:./dev.db"

# ----------------------------------------------------------------------------
# APP_SECRET — REQUIRED. Used to encrypt stored API keys (AES-256-GCM).
#
# Generate a strong secret (>= 32 random bytes) with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   # or
#   openssl rand -hex 32
#
# The server will refuse to start if this value matches a known placeholder.
# IMPORTANT: changing APP_SECRET invalidates all previously stored API keys.
# ----------------------------------------------------------------------------
APP_SECRET="GENERATE_A_STRONG_RANDOM_SECRET_AND_REPLACE_THIS_VALUE"

# HTTP port the API server listens on. Defaults to 8787.
PORT=8787

# Network interface the server binds to. Defaults to 127.0.0.1 (loopback
# only) which is the right choice for a personal-machine app — no other
# device on the LAN can reach it. Set to 0.0.0.0 to expose the API
# to your local network (e.g. to test from your phone), but be aware
# the rate limiter only exempts loopback today.
# HOST=127.0.0.1

# Default AI provider (gemini, openai, anthropic, nvidia, ollama, puter, custom).
DEFAULT_PROVIDER="gemini"

# ----------------------------------------------------------------------------
# Optional settings (uncomment to enable)
# ----------------------------------------------------------------------------
# LLM API timeout in milliseconds (default 180000 = 3 minutes).
# AGENT_LLM_TIMEOUT_MS=180000

# API key for Serper.dev web search. If unset, web_search falls back to DuckDuckGo.
# SERPER_API_KEY=

# Comma-separated list of allowed CORS origins. Defaults to the Vite dev server.
# CORS_ORIGINS="http://localhost:5173"

# Workspace root fallback when no workspace is configured (defaults to cwd).
# DEFAULT_WORKSPACE_ROOT=

# Set to "false" to disable agent tracing spans entirely.
# AGENT_TRACING=true

# Set to "off" to disable the default console span exporter.
# AGENT_TRACING_EXPORTER=console

# Langfuse (https://langfuse.com) — set these to ship traces to Langfuse Cloud
# or a self-hosted instance. When both keys are present the server will
# auto-configure an OTLP/HTTP exporter.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_TRACING_ENVIRONMENT=production

# Maximum characters to keep per tool output before truncation (default 50000).
# TOOL_OUTPUT_MAX_CHARS=50000

# Conversation memory budget. When usage exceeds this fraction of the model's
# context window, auto-compaction is triggered. Value is 0-100 (default 75).
# MEMORY_COMPACTION_THRESHOLD=75
