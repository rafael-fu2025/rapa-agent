{
  "name": "recreate-ui-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Rapa backend — Fastify server, agent loop, and tool implementations.",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:setup": "prisma migrate dev --name init",
    "db:reset": "prisma migrate reset --force",
    "db:migrate-from-mysql": "tsx src/scripts/migrate-from-mysql.ts",
    "db:migrate-from-mysql:apply": "tsx src/scripts/migrate-from-mysql.ts --apply",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.3.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mysql2": "^3.22.5",
    "node-pty": "^1.1.0",
    "pdf-parse": "^1.1.4",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
