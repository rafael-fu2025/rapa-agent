# ─────────────────────────────────────────────────────────────────────────────
# Rapa / Recreate UI — .gitignore
#
# This file is tuned for a Node.js + Vite + Fastify + Prisma + SQLite
# monorepo. It keeps the working tree clean for `git status`, the GitHub
# web UI, and CI caches. Every entry is documented inline so the next
# contributor can tell at a glance what's being excluded and why.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node / npm / build artifacts ───────────────────────────────────────────
# node_modules is huge (often >500MB) and reinstallable from package-lock.json.
node_modules/
# `dist` is the default Vite / tsx output. `web-dist` and `server/dist`
# are the production build outputs that Vite / tsc emit. None belong in
# git — they're regenerated by `npm run build`.
dist/
dist-ssr/
web-dist/
server/dist/
# TypeScript incremental build cache (.tsbuildinfo) and sourcemaps.
*.tsbuildinfo
*.map
*.local

# ── Environment / secrets ──────────────────────────────────────────────────
# NEVER commit .env — it contains APP_SECRET, DATABASE_URL, API keys.
# The committed template is .env.example.
.env
.env.*
!.env.example
# Allow .env files in any subdirectory of the example-only directories
# (currently none, but keeps the rule explicit if we add them later).
!**/.env.example

# ── Logs / runtime diagnostics ───────────────────────────────────────────
# Test output, dev-server logs, build logs.
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
# Local server build artefacts that get dropped by `npm run dev` / `tsc`.
server-build.log
server/build.log
server/tsc.log
# Local SQLite database files (per-instance, not for git).
# Note: the *schema* (prisma/schema.prisma) and *migrations* (prisma/migrations)
# are committed — only the dev.db file itself is excluded.
*.db
*.db-journal
*.db-shm
*.db-wal
*.db.bak
prisma/dev.db
prisma/dev.db-journal
prisma/dev.db-shm
prisma/dev.db-wal
prisma/dev.db.bak-*

# ── Editor / OS / IDE-specific scratch ─────────────────────────────────────
# VSCode: keep the workspace settings file but ignore user overrides.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
# Trae / Cursor / Antigravity / Qoder scratch — local agent / IDE storage.
.vscode-test/
.qoder/
.antigravitycli/
.trae/
.cursor/
.cursorignore
.aider*
.continue/
# Generic OS junk.
.idea
.DS_Store
Thumbs.db
*.swp
*.swo
*.swn
*.bak
*.tmp
# Windows / VSCode legacy file types
*.suo
*.ntvs*
*.njsproj
*.sln
# Local backup files.
*.backup.ts
*.backup.tsx
*.backup.js

# ── Stray debug artefacts in the repo root ─────────────────────────────────
# A few zero-byte / scratch files that have crept in during exploration.
# Listed explicitly so contributors notice if they re-create them.
nul
dump.txt
execution_process_and_tool_call_usage.txt
the final response is not included.txt
tasks.md

# ── Prisma generated client ─────────────────────────────────────────────────
# Prisma generates the client into node_modules/.prisma and
# node_modules/@prisma/client — both excluded by node_modules/ above.
# If we ever switch to a custom `output` in schema.prisma's generator
# block, add the path here.

# ── Coverage / test runner artefacts ───────────────────────────────────────
# Vitest coverage output (text + html reporters).
coverage/
.nyc_output/
lcov.info
# JUnit / CI test reports.
test-results/
playwright-report/
playwright/.cache/

# ── Local dev tools (not part of the public repo) ──────────────────────────
# The `react-vite-login` directory is an experimental scratch project
# from an earlier scaffold. It is NOT part of the Rapa app and is
# excluded until we decide whether to keep it.
react-vite-login/

# Editor / IDE config and CI workflows are personal-machine / org-specific
# and don't belong in a public-facing repo. The `docs/` and
# `deck-minimax-code/` directories are kept locally for the author but
# excluded from the public GitHub mirror.
.github/
.vscode/
docs/
deck-minimax-code/

# `.antigravitycli/`, `.agent-tars/`, etc. are agent runtime scratch
# directories. Already covered by .antigravitycli/ above; this catch-all
# keeps it tidy if new agents are added.
.agent-tars/
.agent-*/
.qoder-cli/
.kiro/
# Antigravity cockpit (when present) and other agent scratch dirs.
.antigravity/
.antigravity-ide/
.antigravity_cockpit/
.ai_completion/
.arduino-create/

# Local debug / telemetry scratch dir. The `.env` file inside
# (e.g. `minimax-duplicate-thinking.env`) is per-session debug config
# (DEBUG_SERVER_URL, session IDs) and not safe to commit.
.dbg/

# ── Test fixtures & build outputs inside the deck demo ─────────────────────
# `deck-minimax-code/` is the slide deck companion project. Its own
# node_modules / lockfile / generated PDFs are excluded, but the source
# slides (slides/slide-*.js) and compile.js are committed.
deck-minimax-code/node_modules/
deck-minimax-code/package-lock.json
# Generated output PDFs (regenerated by `npm run compile` inside the deck).
deck-minimax-code/output/*.pdf
deck-minimax-code/output/*.png

# ── OS / shell history that sometimes lives in the repo root ───────────────
.bash_history
.zsh_history
.psql_history
.python_history
